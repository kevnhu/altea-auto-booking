# Email Configuration (Gmail)
EMAIL_ADDRESS=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password

# Gmail IMAP Settings
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993

# Altea Website Configuration
ALTEA_URL=https://myaltea.app/booking/
ALTEA_USERNAME=your-altea-username
ALTEA_PASSWORD=your-altea-password

# Email Filter Settings
EMAIL_FROM_FILTER=no-reply@myaltea.club
EMAIL_SUBJECT_FILTER=A Spot Has Opened Up

# Booking Configuration
MAX_RETRIES=2
POLL_INTERVAL_SECONDS=1  # Recommended: 1s. Lower values risk Gmail rate limiting with minimal speed benefit.

# Notification Settings
SEND_NOTIFICATIONS=true
NOTIFICATION_EMAIL=your-email@gmail.com
